# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=mystik

# TLS: для Timeweb / managed MySQL с require_secure_transport оставь пустым или true.
# Для локального Docker MySQL без SSL: MYSQL_SSL=false
# По умолчанию, если лежит server/ca.crt — он подхватится автоматически.
# Иначе можно явно: MYSQL_SSL_CA=ca.crt или абсолютный путь
# MYSQL_SSL_REJECT_UNAUTHORIZED=0  (отключить проверку цепочки, не рекомендуется)
MYSQL_SSL=
# MYSQL_SSL_CA=

# Server Configuration
PORT=3001

# Timeweb / PaaS: лучше команда запуска `node index-mysql.js`, не `npm run start`
# (npm ловит SIGTERM при рестарте и шумит в логах).
