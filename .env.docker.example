# Copy this file to .env before `docker compose up`
# cp .env.docker.example .env

# Ports
FRONTEND_PORT=8081
# Только frontend публикуется наружу
# BACKEND_PORT и MYSQL_PORT намеренно не используются в prod-compose

# MySQL
MYSQL_DATABASE=mystik
MYSQL_USER=mystik_user
MYSQL_PASSWORD=mystik_password
MYSQL_ROOT_PASSWORD=root_password

# Frontend build arg (keep /api for nginx proxy)
VITE_API_URL=/api
